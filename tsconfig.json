{
  "compilerOptions": {
    // ES2022 target — supported by Cloudflare Workers runtime
    "target": "ES2022",
    "module": "ES2022",
    // bundler resolution is the modern choice for Cloudflare Workers + Hono
    "moduleResolution": "bundler",
    "lib": ["ES2022"],

    // Strict mode — no exceptions
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // Types are generated by `wrangler types` into worker-configuration.d.ts.
    // Do NOT add @cloudflare/workers-types — it conflicts with generated types.
    // Rerun: npx wrangler types after any wrangler.jsonc binding change.

    // skipLibCheck: avoids duplicate global type conflicts between
    // worker-configuration.d.ts (wrangler types) and @types/node (nodejs_compat).
    // This is standard practice for Cloudflare Workers + nodejs_compat projects.
    "skipLibCheck": true,

    // Allow .ts extensions in imports (required for Workers + bundler resolution)
    "allowImportingTsExtensions": true,
    "noEmit": true,

    // Path aliases
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "worker-configuration.d.ts"],
  "exclude": ["node_modules", "dist"]
}
